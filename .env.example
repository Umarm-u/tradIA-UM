# ─────────────────────────────────────────────
# tradIA Live Trading — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# Binance API Credentials (Futures-enabled)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Settings
SYMBOL=BTCUSDT
LEVERAGE=5
DRY_RUN=True

# Risk Management
RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05

# Signal Thresholds
BUY_THRESHOLD=0.600
SELL_THRESHOLD=0.775

# Meta-model Filter
META_FILTER_ENABLED=True
META_THRESHOLD=0.30
